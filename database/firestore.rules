// Firestore en este proyecto se usa como capa de lectura/proyección para cliente.
// La fuente canónica relacional está en Cloud SQL (ver docs/CloudSQL-vs-Firestore.md).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isEditor() {
      return hasRole('editor');
    }

    function isAdminOrEditor() {
      return isAdmin() || isEditor();
    }

    function isPremium() {
      return isAuthenticated() && request.auth.token.premium == true;
    }

    function hasSongUnlock(songId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/songUnlocks/$(songId));
    }

    match /users/{userId} {
      allow read, create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /favorites/{songId} {
        allow read, write: if isOwner(userId);

        match /versions/{versionId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /songPreferences/{songId} {
        allow read, write: if isOwner(userId);
      }

      match /purchaseIntents/{songId} {
        allow read, write: if isOwner(userId);
      }

      match /songUnlocks/{songId} {
        allow read: if isOwner(userId);
        allow write: if isAdmin();
      }

      match /private/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /subscriptions/{subscriptionId} {
      // Colección de lectura/proyección; estado canónico de suscripción en Cloud SQL.
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if true;
      allow write: if isAdmin();

      match /versions/{versionId} {
        allow read: if resource.data.isPremium == false || isPremium() || hasSongUnlock(songId);
        allow write: if isAdmin();
      }
    }

    match /misales/{misalId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrEditor();
    }

    match /artists/{artistId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /repertoires/{repertoireId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || resource.data.visibility == 'public'
          || resource.data.isPublic == true);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());

      match /songs/{songId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && (get(/databases/$(database)/documents/repertoires/$(repertoireId)).data.userId == request.auth.uid
            || isAdmin());
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
