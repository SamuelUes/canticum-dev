// Storage guarda binarios; permisos de negocio se alinean con Firestore/Cloud SQL.
// Ver contrato: database/DATA_CONTRACT.md y docs/CloudSQL-vs-Firestore.md
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdminOrEditor() {
      return hasRole('admin') || hasRole('editor');
    }

    function isPremium() {
      return isAuthenticated() && request.auth.token.premium == true;
    }

    function hasSongUnlock(songId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/songUnlocks/$(songId));
    }

    function canUploadRepertoireCover(repertoireId) {
      return isAdminOrEditor() || isAuthenticated();
    }

    function isSongOwner(songId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/songs/$(songId))
        && (
          firestore.get(/databases/(default)/documents/songs/$(songId)).data.ownerUserId == request.auth.uid
          || firestore.get(/databases/(default)/documents/songs/$(songId)).data.createdBy == request.auth.uid
        );
    }

    function canWriteSongAssets(songId) {
      return isAdminOrEditor()
        || isSongOwner(songId)
        || (isAuthenticated() && !firestore.exists(/databases/(default)/documents/songs/$(songId)));
    }

    match /songs/{songId}/lyrics/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /songs/{songId}/audio/reference/{fileName} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /songs/{songId}/audio/premium/{fileName} {
      allow read: if isPremium() || hasSongUnlock(songId);
      allow write: if isAdminOrEditor();
    }

    match /songs/{songId}/sheet/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    // Per-version assets (audio, lyrics file, sheet file).
    // Reads are public for non-premium, owner-only granular checks delegated to backend.
    // Writes allowed for owner/admin/editor.
    // Sheet files (PDF, PNG, JPG, MusicXML/MXL) are publicly readable for browser rendering.
    match /songs/{songId}/versions/{versionId}/audio/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteSongAssets(songId);
    }

    match /songs/{songId}/versions/{versionId}/lyrics/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteSongAssets(songId);
    }

    match /songs/{songId}/versions/{versionId}/sheet/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteSongAssets(songId);
    }

    match /songs/{songId}/versions/{versionId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteSongAssets(songId);
    }

    // Per-instrumentation assets (audio, lyrics, sheet files).
    // Supports the new data model where 1 version can have multiple instrumentations.
    match /songs/{songId}/versions/{versionId}/instrumentations/{instrumentationId}/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteSongAssets(songId);
    }

    match /songs/{songId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /albums/{albumId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /repertoires/{repertoireId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if canUploadRepertoireCover(repertoireId);
    }

    match /artists/{artistId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /misal__plan/{weekId}/{misal_planId}/{leafId} {
      allow read: if true;
      allow write: if isAdminOrEditor()
        && weekId.size() > 0 && weekId.size() <= 40
        && misal_planId.size() > 0 && misal_planId.size() <= 80
        && leafId.size() > 0 && leafId.size() <= 80
        && request.resource.size < 20 * 1024 * 1024
        && (
          (leafId.matches('^misal_[A-Za-z0-9_-]+$') && request.resource.contentType == 'application/pdf')
          || (leafId.matches('^schema_[A-Za-z0-9_-]+$') && request.resource.contentType == 'text/plain')
        );
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
