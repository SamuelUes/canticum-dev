{
  "name": "Canticum-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo frontend for Canticum (Next.js + Expo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start",
    "dev:web": "npm --prefix apps/web run dev",
    "start:web": "npm --prefix apps/web run start",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "i18n": "^0.15.3",
    "react-beautiful-dnd": "^13.1.1",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@types/react-beautiful-dnd": "^13.1.8"
  }
}
